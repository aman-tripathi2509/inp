    "/api/saveFeedback": {
      "post": {
        "summary": "save the employee feedback data in the inp_employee_feedback table",
        "tags": ["User Feedback"],
        "description": "save the employee feedback data in the inp_employee_feedback table",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "member_id": {
                    "type": "integer",
                    "example": 2025103
                  },
                  "company_id": {
                    "type": "integer",
                    "example": 178
                  },
                  "employee_satisfaction_rating": {
                    "type": "float",
                    "example": 2.4
                  },
                  "company_culture_rating": {
                    "type": "float",
                    "example": 1.5
                  },
                  "easy_of_working_rating": {
                    "type": "float",
                    "example": 2.6
                  },
                  "work_life_balance_rating": {
                    "type": "float",
